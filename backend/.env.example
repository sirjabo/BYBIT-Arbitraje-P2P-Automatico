# Bybit API Credentials
# Get these from: https://www.bybit.com/en/user-service/settings/api
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Bot Configuration
BYBIT_BASE_URL=https://api.bybit.com

# P2P Ad IDs (get these from your Bybit P2P merchant dashboard)
BUY_AD_ID=your_buy_ad_id_here
SELL_AD_ID=your_sell_ad_id_here

# Pricing Config
MIN_SPREAD_PERCENT=0.3
TICK_SIZE=1.0
MIN_CHANGE_THRESHOLD_PERCENT=0.15

# Bot operational config
UPDATE_INTERVAL_MS=15000
COOLDOWN_AFTER_UPDATE_MS=30000
MAX_UPDATES_PER_5MIN=10
MAX_REQUESTS_PER_SEC=5

# Server
PORT=3002
WS_PORT=3002

# Logging
LOG_LEVEL=info
